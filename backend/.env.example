# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/exploded_view

# ── Storage ─────────────────────────────────────────────────────────────────────
# Absolute path to the shared storage directory at the project root.
# Both Node.js and Python read this value — keep it consistent.
STORAGE_PATH=../storage

# ── Python ──────────────────────────────────────────────────────────────────────
# Path to the Python interpreter (use 'python' or full venv path)
PYTHON_EXECUTABLE=python

# Path to the Python worker entry point
PYTHON_WORKER_PATH=../ai-worker/main.py

# ── Job Lifecycle ────────────────────────────────────────────────────────────────
# Number of days before a completed job and its files are purged
JOB_TTL_DAYS=7

# ── File Upload ──────────────────────────────────────────────────────────────────
# Maximum PDF upload size in megabytes
MAX_UPLOAD_SIZE_MB=50
