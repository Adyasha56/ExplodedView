# ── Environment variables (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.production

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── Storage (runtime data, not source code) ───────────────────────────────────
storage/uploads/*
storage/outputs/*
!storage/uploads/.gitkeep
!storage/outputs/.gitkeep

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
