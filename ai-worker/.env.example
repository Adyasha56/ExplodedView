# ── Storage ───────────────────────────────────────────────────────────────────
# Must match the value set in backend/.env
STORAGE_PATH=../storage

# ── Pipeline Behaviour ────────────────────────────────────────────────────────
# Set to "true" to save preprocessed.png alongside diagram.png for debugging
DEBUG=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
